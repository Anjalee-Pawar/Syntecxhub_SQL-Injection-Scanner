"""
Tiny intentionally-vulnerable Flask app, for LOCAL testing of sqli_scanner.py
only. Do not deploy this anywhere. It builds raw SQL strings on purpose.
"""
from flask import Flask, request
import sqlite3
import os

app = Flask(__name__)
DB_PATH = "/tmp/test_lab.db"


def init_db():
    if os.path.exists(DB_PATH):
        os.remove(DB_PATH)
    conn = sqlite3.connect(DB_PATH)
    conn.execute("CREATE TABLE users (id INTEGER, username TEXT, secret TEXT)")
    conn.execute("INSERT INTO users VALUES (1, 'alice', 'flag{alice_secret}')")
    conn.execute("INSERT INTO users VALUES (2, 'bob', 'flag{bob_secret}')")
    conn.commit()
    conn.close()


@app.route("/search")
def search():
    id_param = request.args.get("id", "1")
    conn = sqlite3.connect(DB_PATH)
    cur = conn.cursor()
    # Intentionally vulnerable: raw string interpolation
    query = f"SELECT id, username FROM users WHERE id = '{id_param}'"
    try:
        cur.execute(query)
        rows = cur.fetchall()
        return {"query": query, "rows": rows}
    except sqlite3.OperationalError as e:
        return {"query": query, "error": str(e)}, 500
    finally:
        conn.close()


if __name__ == "__main__":
    init_db()
    app.run(host="127.0.0.1", port=5055)
